<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /admin/
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /admin/index.html [L]
</IfModule>

# Block direct HTTP access to Node.js server files
<FilesMatch "^(start\.js|package\.json|package-lock\.json)$">
  Require all denied
</FilesMatch>
