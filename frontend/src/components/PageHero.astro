---
import WaveDivider from './WaveDivider.astro';

interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  maxWidth?: string;
}
const { eyebrow, title, description, maxWidth = 'max-w-[720px]' } = Astro.props;
---

<section class="relative overflow-hidden bg-[linear-gradient(155deg,#3FAE68_0%,#1F7A4D_70%,#176B43_100%)]">
  <div class="pointer-events-none absolute -right-28 -top-20 h-[340px] w-[340px] rounded-full bg-[radial-gradient(circle,rgba(244,185,66,0.32),transparent_68%)]"></div>
  <div class="pointer-events-none absolute -left-24 -bottom-10 h-[260px] w-[260px] rounded-full bg-[radial-gradient(circle,rgba(31,90,166,0.3),transparent_70%)]"></div>

  <div class="relative mx-auto max-w-[1240px] px-6 py-10 text-center md:px-10 md:py-12 md:pb-24">
    <span class="mb-5 inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-2 font-display text-xs font-semibold uppercase tracking-[0.14em] text-white">
      <span class="h-[7px] w-[7px] rounded-full bg-gold"></span>
      {eyebrow}
    </span>
    <h1 class:list={['mx-auto font-display text-4xl font-extrabold leading-[1.08] tracking-tight text-white md:text-[58px]', maxWidth]}>
      {title}
    </h1>
    {description && (
      <p class="mx-auto mt-5 max-w-[580px] text-lg leading-relaxed text-white/90">{description}</p>
    )}
  </div>

  <WaveDivider fill="#fff" />
</section>
