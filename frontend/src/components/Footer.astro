---
import NewsletterForm from './NewsletterForm';
---

<footer class="bg-forest-900 px-6 pb-8 pt-14 md:px-10">
  <div class="mx-auto max-w-[1240px]">
    <div class="grid gap-10 border-b border-white/[0.14] pb-10 md:grid-cols-4">
      <div>
        <div class="flex items-center gap-2">
          <img src="/images/logo-icon.png" alt="" class="h-10 w-auto" />
          <span class="font-display text-lg font-bold leading-none text-white">Hope For Families</span>
        </div>
        <p class="mt-4 max-w-[240px] text-sm leading-relaxed text-white/65">
          Building stronger families, empowered communities and brighter futures across Scotland.
        </p>
        <p class="mt-3 text-xs text-white/45">Charity No: SC053715</p>
      </div>

      <div>
        <div class="mb-4 font-display text-sm font-bold text-white">Explore</div>
        <div class="flex flex-col gap-2.5 text-sm">
          <a href="/about" class="text-white/65 hover:text-gold">About us</a>
          <a href="/programs" class="text-white/65 hover:text-gold">Programs</a>
          <a href="/events" class="text-white/65 hover:text-gold">Events</a>
          <a href="/success-stories" class="text-white/65 hover:text-gold">Success stories</a>
          <a href="/blog" class="text-white/65 hover:text-gold">Blog & news</a>
        </div>
      </div>

      <div>
        <div class="mb-4 font-display text-sm font-bold text-white">Get involved</div>
        <div class="flex flex-col gap-2.5 text-sm">
          <a href="/donate" class="text-white/65 hover:text-gold">Donate</a>
          <a href="/get-involved" class="text-white/65 hover:text-gold">Volunteer</a>
          <a href="/get-involved" class="text-white/65 hover:text-gold">Partnerships</a>
          <a href="/resources" class="text-white/65 hover:text-gold">Resources & policies</a>
          <a href="/contact" class="text-white/65 hover:text-gold">Contact</a>
        </div>
      </div>

      <div>
        <div class="mb-4 font-display text-sm font-bold text-white">Stay in touch</div>
        <p class="mb-3 text-[13px] leading-relaxed text-white/65">Get news &amp; stories from our community.</p>
        <NewsletterForm client:visible />
        <div class="mt-5 flex gap-4 text-sm">
          <a href="https://www.instagram.com/hopeforfamilies" target="_blank" rel="noopener" class="text-white/65 hover:text-gold">Instagram</a>
          <a href="https://www.facebook.com/share/1EiJxZpgKo/?mibextid=wwXIfr" target="_blank" rel="noopener" class="text-white/65 hover:text-gold">Facebook</a>
          <a href="https://www.tiktok.com/@hopeforfamiliesdundee" target="_blank" rel="noopener" class="text-white/65 hover:text-gold">TikTok</a>
        </div>
      </div>
    </div>

    <div class="flex flex-col items-center justify-between gap-2 pt-5 text-xs text-white/50 md:flex-row">
      <span>&copy; {new Date().getFullYear()} Hope For Families &middot; Scottish Charity SC053715 &middot; Dundee, Scotland</span>
      <span>Privacy &middot; Safeguarding &middot; Cookies</span>
    </div>
  </div>
</footer>
