---
const navItems = [
  { href: '/about', label: 'About' },
  { href: '/programs', label: 'Programs' },
  { href: '/events', label: 'Events' },
  { href: '/success-stories', label: 'Stories' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/blog', label: 'Blog' },
  { href: '/resources', label: 'Resources' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  return href === '/' ? currentPath === '/' : currentPath.startsWith(href);
}
---

<div class="relative bg-[linear-gradient(155deg,#3FAE68_0%,#1F7A4D_70%,#176B43_100%)]">
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="absolute -right-28 -top-20 h-[340px] w-[340px] rounded-full bg-[radial-gradient(circle,rgba(244,185,66,0.32),transparent_68%)]"></div>
    <div class="absolute -left-24 -bottom-16 h-[260px] w-[260px] rounded-full bg-[radial-gradient(circle,rgba(31,90,166,0.3),transparent_70%)]"></div>
  </div>

  <nav class="relative mx-auto flex max-w-[1240px] items-center justify-between gap-4 px-6 py-5 md:px-10">
    <a href="/" class="flex shrink-0 items-center gap-2">
      <img src="/images/logo-icon.png" alt="" class="h-9 w-auto" />
      <span class="font-display text-lg font-bold leading-none text-white">Hope For Families</span>
    </a>

    <div class="hidden items-center gap-5 xl:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['navlink text-[13px] font-medium text-white/90 whitespace-nowrap', { 'active font-semibold text-white': isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://checkout.justgiving.com/908482wxjj"
        target="_blank"
        rel="noopener"
        class="btn-lift inline-flex shrink-0 items-center gap-1.5 rounded-full bg-white px-5 py-2.5 font-display text-sm font-bold text-forest-800"
      >
        Donate
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="flex shrink-0 items-center gap-2.5 xl:hidden">
      <a
        href="https://checkout.justgiving.com/908482wxjj"
        target="_blank"
        rel="noopener"
        class="btn-lift inline-flex shrink-0 items-center gap-1.5 rounded-full bg-white px-4 py-2 font-display text-sm font-bold text-forest-800"
      >
        Donate
      </a>

      <details class="group relative">
        <summary class="flex h-10 w-10 list-none items-center justify-center rounded-full bg-white/15 text-white [&::-webkit-details-marker]:hidden">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" class="transition-transform group-open:rotate-90">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </summary>
        <div class="absolute right-0 top-[calc(100%+10px)] z-50 w-60 rounded-2xl bg-white p-2.5 shadow-[0_20px_44px_-16px_rgba(0,0,0,0.35)]">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'block rounded-xl px-4 py-2.5 font-display text-sm font-semibold',
                isActive(item.href) ? 'bg-mint text-emerald-deep' : 'text-forest-900 hover:bg-mint',
              ]}
            >
              {item.label}
            </a>
          ))}
        </div>
      </details>
    </div>
  </nav>
</div>
