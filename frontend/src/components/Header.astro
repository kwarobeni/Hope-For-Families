---
const navItems = [
  { href: '/about', label: 'About' },
  { href: '/programs', label: 'Programs' },
  { href: '/events', label: 'Events' },
  { href: '/success-stories', label: 'Stories' },
  { href: '/get-involved', label: 'Get Involved' },
  { href: '/blog', label: 'Blog' },
  { href: '/resources', label: 'Resources' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  return href === '/' ? currentPath === '/' : currentPath.startsWith(href);
}
---

<div class="relative overflow-hidden bg-[linear-gradient(155deg,#3FAE68_0%,#1F7A4D_70%,#176B43_100%)]">
  <div class="pointer-events-none absolute -right-28 -top-20 h-[340px] w-[340px] rounded-full bg-[radial-gradient(circle,rgba(244,185,66,0.32),transparent_68%)]"></div>
  <div class="pointer-events-none absolute -left-24 -bottom-16 h-[260px] w-[260px] rounded-full bg-[radial-gradient(circle,rgba(31,90,166,0.3),transparent_70%)]"></div>

  <nav class="relative mx-auto flex max-w-[1240px] items-center justify-between gap-4 px-6 py-5 md:px-10">
    <a href="/" class="flex shrink-0 items-center gap-1.5">
      <span class="font-script text-[28px] leading-none text-white" style="font-family: var(--font-script);">hope</span>
      <svg width="14" height="14" viewBox="0 0 24 24" class="mb-1"><path fill="#F4B942" d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54z"/></svg>
      <span class="ml-1 self-center text-[8px] font-semibold tracking-[0.3em] text-white/70">FOR FAMILIES</span>
    </a>

    <div class="hidden items-center gap-5 xl:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={['navlink text-[13px] font-medium text-white/90 whitespace-nowrap', { 'active font-semibold text-white': isActive(item.href) }]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="/donate"
        class:list={[
          'btn-lift inline-flex shrink-0 items-center gap-1.5 rounded-full px-5 py-2.5 font-display text-sm font-bold',
          isActive('/donate') ? 'bg-gold text-forest-900' : 'bg-white text-forest-800',
        ]}
      >
        Donate
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <a
      href="/donate"
      class="btn-lift inline-flex shrink-0 items-center gap-1.5 rounded-full bg-white px-4 py-2 font-display text-sm font-bold text-forest-800 xl:hidden"
    >
      Donate
    </a>
  </nav>

  <nav class="relative flex gap-4 overflow-x-auto px-6 pb-4 text-[13px] font-medium xl:hidden">
    {navItems.map((item) => (
      <a
        href={item.href}
        class:list={['whitespace-nowrap text-white/85', { 'font-semibold text-white underline decoration-gold decoration-2 underline-offset-4': isActive(item.href) }]}
      >
        {item.label}
      </a>
    ))}
  </nav>
</div>
