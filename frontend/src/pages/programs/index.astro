---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import { api } from '../../lib/api';

const initiatives = await api.initiatives();
const [flagship, ...rest] = initiatives;
const gradients = [
  'bg-[linear-gradient(150deg,#1F5AA6,#3FAE68)]',
  'bg-[linear-gradient(150deg,#3FAE68,#F4B942)]',
  'bg-[linear-gradient(150deg,#F4B942,#e0796b)]',
  'bg-[linear-gradient(150deg,#3FAE68,#1F5AA6)]',
];
const programPhotos: Record<string, string> = {
  'little-stars': '/images/little-stars.jpg',
  'firstpass-football': '/images/football.jpg',
};
---

<Layout title="Programs" description="Explore Hope For Families' core initiatives: Adolescent Development, Mental Health & Wellbeing, Little Stars, FirstPass Football Academy, and the Food Bank & Café.">
  <PageHero
    eyebrow="What we do"
    title="Our programs, one community."
    description="From a warm meal to a STEM club, every program is a doorway into belonging. All are open, all are free, and all are run with love."
    maxWidth="max-w-[760px]"
  />

  {flagship && (
    <section class="bg-white px-6 pb-10 pt-10 md:px-10">
      <a href={`/programs/${flagship.slug}`} class="card-lift mx-auto grid max-w-[1240px] overflow-hidden rounded-[28px] border border-border-soft bg-white shadow-[0_22px_48px_-28px_rgba(20,84,58,0.45)] md:grid-cols-[1.1fr_1fr]">
        <div class="relative min-h-[240px] md:min-h-[380px]">
          <img src="/images/family-support.jpg" alt={flagship.title} class="absolute inset-0 h-full w-full object-cover" />
          <span class="absolute left-4.5 top-4.5 rounded-full bg-gold px-3.5 py-2 font-display text-[11px] font-bold uppercase tracking-[0.08em] text-forest-900">Flagship program</span>
        </div>
        <div class="p-8 md:p-12">
          <h2 class="mb-3.5 font-display text-3xl font-bold leading-[1.12] text-forest-900">{flagship.title}</h2>
          {flagship.tagline && <p class="mb-3 font-display text-base font-semibold text-emerald-deep">{flagship.tagline}</p>}
          <p class="mb-7 leading-[1.7] text-body">{flagship.description}</p>
          <span class="inline-flex items-center gap-2 rounded-full bg-emerald-deep px-6 py-3.5 font-display text-sm font-bold text-white">
            View program
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </div>
      </a>
    </section>
  )}

  {rest.length > 0 && (
    <section class="bg-white px-6 pb-21 pt-2 md:px-10">
      <div class="mx-auto grid max-w-[1240px] gap-6 md:grid-cols-2">
        {rest.map((initiative, i) => (
          <a href={`/programs/${initiative.slug}`} class="card-lift flex flex-col overflow-hidden rounded-[24px] border border-border-soft bg-white shadow-[0_14px_34px_-28px_rgba(20,84,58,0.4)]">
            {programPhotos[initiative.slug] ? (
              <div class="h-36 w-full overflow-hidden">
                <img src={programPhotos[initiative.slug]} alt={initiative.title} class="h-full w-full object-cover" />
              </div>
            ) : null}
            <div class="flex flex-1 flex-col p-7">
            {!programPhotos[initiative.slug] && (
              <div class={`mb-4.5 flex h-14 w-14 items-center justify-center rounded-full ${gradients[i % gradients.length]}`}>
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.6"><path d="M12 3l9 4.5-9 4.5-9-4.5L12 3z"/><path d="M3 12l9 4.5 9-4.5"/></svg>
              </div>
            )}
            <h2 class="mb-1.5 font-display text-xl font-bold text-forest-900">{initiative.title}</h2>
            {initiative.tagline && <p class="mb-2.5 font-display text-sm font-semibold text-emerald-deep">{initiative.tagline}</p>}
            <p class="mb-4 text-sm leading-relaxed text-body">{initiative.description}</p>
            <span class="mt-auto inline-flex items-center gap-1.5 font-display text-sm font-bold text-emerald-deep">
              View program
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#2E8B57" stroke-width="2.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <CtaBand title="Help us keep these doors open." description="Every program runs on the generosity of donors and volunteers. Join us." />
</Layout>
