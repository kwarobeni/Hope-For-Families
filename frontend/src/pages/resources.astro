---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';

const categories = [
  {
    label: 'Safeguarding & Conduct',
    items: [
      {
        title: 'Safeguarding Policy',
        description: 'Our commitment to the safety and welfare of every child, young person and vulnerable adult in our care — including reporting procedures and safer recruitment.',
        href: '/policies/safeguarding',
        icon: 'shield',
      },
      {
        title: 'Code of Conduct',
        description: 'Standards of behaviour expected from all staff, volunteers and participants at Hope For Families, including inclusion, boundaries and confidentiality.',
        href: '/policies/code-of-conduct',
        icon: 'check',
      },
      {
        title: 'Consent Policy',
        description: 'How we obtain, record and respect consent for activities, photography and personal data — including parental consent for under-18s.',
        href: '/policies/consent',
        icon: 'pen',
      },
    ],
  },
  {
    label: 'Legal & Privacy',
    items: [
      {
        title: 'Privacy Policy',
        description: 'How we collect, use, store and protect your personal information in line with UK GDPR and the Data Protection Act 2018.',
        href: '/policies/privacy-policy',
        icon: 'lock',
      },
      {
        title: 'GDPR Compliance',
        description: 'Our framework for responsible data processing, lawful bases we rely on, and the rights you hold under UK data protection law.',
        href: '/policies/gdpr',
        icon: 'database',
      },
      {
        title: 'Terms of Use',
        description: 'The terms governing your use of our website, including intellectual property, acceptable use and limitation of liability.',
        href: '/policies/terms',
        icon: 'document',
      },
      {
        title: 'Cookie Policy',
        description: 'What cookies we use on our website, why we use them, and how to manage or disable them through your browser settings.',
        href: '/policies/cookies',
        icon: 'globe',
      },
    ],
  },
  {
    label: 'Financial Transparency',
    items: [
      {
        title: 'Donation Disclaimer',
        description: 'How your donations are allocated across our programmes, our Gift Aid approach, and our accountability as a registered Scottish charity (SC053715).',
        href: '/policies/donation-disclaimer',
        icon: 'heart',
      },
    ],
  },
];

const icons: Record<string, string> = {
  shield: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  check: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>`,
  pen: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
  lock: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
  database: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4.03 3-9 3S3 13.66 3 12"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/></svg>`,
  document: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  globe: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
  heart: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
};
---

<Layout title="Resources & Policies" description="Download or read Hope For Families' policies and documents — including Safeguarding, Privacy Policy, Code of Conduct, GDPR Compliance and more.">
  <PageHero
    eyebrow="Transparency"
    title="Resources & policies."
    description="We believe in being open about how we work, how we protect our community, and how we use the trust placed in us. All our policies are available to read here."
    maxWidth="max-w-[660px]"
  />

  <section class="bg-white px-6 pb-6 pt-12 md:px-10">
    <div class="mx-auto max-w-[860px] space-y-14">

      {categories.map((cat) => (
        <div>
          <div class="mb-5 flex items-center gap-3">
            <span class="h-0.5 w-7 bg-emerald-deep"></span>
            <h2 class="font-display text-sm font-bold uppercase tracking-[0.18em] text-emerald-deep">{cat.label}</h2>
          </div>
          <div class="flex flex-col gap-3">
            {cat.items.map((item) => (
              <a
                href={item.href}
                class="group flex items-start gap-5 rounded-[20px] border border-border-soft bg-mint px-6 py-5 transition-all hover:border-emerald-deep/30 hover:shadow-[0_8px_24px_-16px_rgba(20,84,58,0.28)]"
              >
                <div class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-white text-emerald-deep shadow-[0_4px_12px_-6px_rgba(20,84,58,0.25)]">
                  <Fragment set:html={icons[item.icon] ?? icons['document']} />
                </div>
                <div class="min-w-0 flex-1">
                  <h3 class="mb-1 font-display text-[17px] font-bold leading-snug text-forest-900 group-hover:text-emerald-deep">
                    {item.title}
                  </h3>
                  <p class="text-[14px] leading-relaxed text-muted">{item.description}</p>
                </div>
                <div class="mt-1 shrink-0 text-emerald-deep opacity-0 transition-opacity group-hover:opacity-100">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
                    <path d="M5 12h14M13 6l6 6-6 6"/>
                  </svg>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}

    </div>
  </section>

  <!-- Charity info footer -->
  <section class="bg-white px-6 pb-20 pt-14 md:px-10">
    <div class="mx-auto max-w-[860px] rounded-[22px] border border-border-soft bg-mint p-7 md:p-9">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="mb-1 font-display text-sm font-bold text-forest-900">Hope For Families</p>
          <p class="text-sm text-muted">Scottish Charitable Incorporated Organisation &middot; Charity Number SC053715</p>
          <p class="text-sm text-muted">Regulated by the Office of the Scottish Charity Regulator (OSCR)</p>
        </div>
        <a
          href="https://www.oscr.org.uk/about-charities/search-the-register/"
          target="_blank"
          rel="noopener"
          class="inline-flex shrink-0 items-center gap-2 rounded-full border border-emerald-deep/30 bg-white px-5 py-2.5 font-display text-sm font-bold text-emerald-deep transition-colors hover:bg-emerald-deep hover:text-white"
        >
          Verify on OSCR
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <CtaBand
    title="Have a question about our policies?"
    description="We're always happy to explain how we work. Get in touch and we'll respond within two working days."
    bgImage="/images/moment-2.jpg"
  />
</Layout>
