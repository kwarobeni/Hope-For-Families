---
import Layout from '../../layouts/Layout.astro';
import WaveDivider from '../../components/WaveDivider.astro';
import EventRegisterForm from '../../components/EventRegisterForm';
import { api } from '../../lib/api';

export async function getStaticPaths() {
  const events = await api.events();
  return events.map((event) => ({ params: { slug: event.slug } }));
}

const { slug } = Astro.params;
const event = await api.eventBySlug(slug as string);

if (!event) {
  return Astro.redirect('/events');
}

const isFull = event.capacity ? event.registration_count >= event.capacity : false;
const formattedDate = new Date(event.start_at).toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  hour: 'numeric',
  minute: '2-digit',
});
---

<Layout title={event.title} description={event.description}>
  <section class="relative overflow-hidden bg-[linear-gradient(155deg,#3FAE68_0%,#1F7A4D_70%,#176B43_100%)]">
    <div class="pointer-events-none absolute -right-28 -top-20 h-[340px] w-[340px] rounded-full bg-[radial-gradient(circle,rgba(244,185,66,0.32),transparent_68%)]"></div>
    <div class="relative mx-auto max-w-[1240px] px-6 py-10 md:px-10 md:pb-24">
      <a href="/events" class="navlink inline-flex items-center gap-1.5 font-display text-sm font-semibold text-white/85">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        All Events
      </a>
      <h1 class="mt-4 max-w-[760px] font-display text-4xl font-extrabold leading-[1.08] text-white md:text-[52px]">{event.title}</h1>
      <p class="mt-3 flex items-center gap-2 text-white/90">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#F4B942" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        {formattedDate}{event.location ? ` · ${event.location}` : ''}
      </p>
    </div>
    <WaveDivider fill="#fff" />
  </section>

  <section class="bg-white px-6 pb-21 pt-10 md:px-10">
    <div class="mx-auto max-w-[840px]">
      <p class="text-lg leading-[1.75] text-body">{event.description}</p>

      {event.photos.length > 0 && (
        <div class="mt-10 grid grid-cols-2 gap-3 md:grid-cols-3">
          {event.photos.map((photo) => (
            <img src={photo.image} alt={photo.caption || event.title} class="h-40 w-full rounded-2xl object-cover" />
          ))}
        </div>
      )}

      <div class="mt-12 rounded-[24px] bg-mint p-8 md:p-10">
        <h2 class="mb-5 font-display text-2xl font-bold text-forest-900">Register for this Event</h2>
        {!event.registration_open && <p class="text-muted">Registration is closed for this event.</p>}
        {event.registration_open && isFull && <p class="font-semibold text-coral">This event is fully booked.</p>}
        {event.registration_open && !isFull && <EventRegisterForm client:load eventId={event.id} />}
      </div>
    </div>
  </section>
</Layout>
