---
import Layout from '../layouts/Layout.astro';
import WaveDivider from '../components/WaveDivider.astro';
import CtaBand from '../components/CtaBand.astro';
import ImpactCounters from '../components/ImpactCounters';
import { api } from '../lib/api';

const [initiatives, stats, testimonials, events] = await Promise.all([
  api.initiatives(),
  api.impactStats(),
  api.testimonials(),
  api.events(),
]);

const featured = testimonials.find((t) => t.is_featured) ?? testimonials[0];
const [flagship, ...restInitiatives] = initiatives;

const now = Date.now();
const upcomingEvents = events.filter((e) => new Date(e.start_at).getTime() >= now).slice(0, 3);

const spineColors = ['bg-emerald-deep', 'bg-gold-deep', 'bg-hope-blue'];

function formatDate(d: string) {
  return new Date(d).toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
}

const values = [
  ['Inclusion', 'We create welcoming spaces where everyone feels valued and heard.'],
  ['Empowerment', 'We inspire confidence and help people build their potential.'],
  ['Community', 'We believe strong communities are built through connection.'],
  ['Compassion', 'We serve with kindness and a genuine commitment to improving lives.'],
];

const programPhotos: Record<string, string> = {
  'little-stars': '/images/little-stars.jpg',
  'firstpass-football': '/images/football.jpg',
};
---

<Layout title="Home">
  <!-- HERO -->
  <section class="relative overflow-hidden bg-[linear-gradient(155deg,#3FAE68_0%,#1F7A4D_70%,#176B43_100%)]">
    <div class="pointer-events-none absolute -right-28 -top-20 h-[420px] w-[420px] rounded-full bg-[radial-gradient(circle,rgba(244,185,66,0.32),transparent_68%)]"></div>
    <div class="pointer-events-none absolute -left-24 bottom-10 h-[340px] w-[340px] rounded-full bg-[radial-gradient(circle,rgba(31,90,166,0.3),transparent_70%)]"></div>

    <div class="relative mx-auto grid max-w-[1240px] items-center gap-10 px-6 py-11 pb-24 md:grid-cols-[1.05fr_0.95fr] md:px-10 md:pb-28">
      <div>
        <span class="mb-6 inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-2 font-display text-xs font-semibold uppercase tracking-[0.14em] text-white">
          <span class="h-[7px] w-[7px] rounded-full bg-gold"></span>Dundee &middot; Scotland
        </span>
        <h1 class="max-w-[560px] font-display text-4xl font-extrabold leading-[1.08] tracking-tight text-white sm:text-5xl sm:leading-[1.03] md:text-[64px]">
          Where every family finds <span class="text-gold">hope.</span>
        </h1>
        <p class="mt-5 max-w-[470px] text-lg leading-relaxed text-white/90">
          Building stronger families, empowered communities and brighter futures for African and ethnic-minority
          families across Scotland.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3.5">
          <a href="/donate" class="btn-lift inline-flex items-center gap-2 rounded-full bg-gold px-7 py-4 font-display text-base font-bold text-forest-700 shadow-[0_14px_30px_-12px_rgba(244,185,66,0.6)]">
            Donate today
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1F7A4D" stroke-width="2.6"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a href="/programs" class="btn-lift inline-flex items-center gap-2 rounded-full border-[1.5px] border-white/50 bg-white/15 px-6 py-3.5 font-display text-base font-bold text-white">
            Discover programs
          </a>
        </div>
      </div>

      <div class="mb-2 h-56 w-full overflow-hidden rounded-[28px] shadow-[0_16px_36px_-16px_rgba(0,0,0,0.3)] md:hidden">
        <img src="/images/hero-family.jpg" alt="A happy family together" class="h-full w-full object-cover" />
      </div>

      <div class="relative hidden h-[400px] md:block">
        <div class="absolute right-8 top-3 h-[300px] w-[240px] overflow-hidden rounded-[140px_140px_130px_130px] shadow-[0_24px_50px_-20px_rgba(0,0,0,0.3)]">
          <img src="/images/hero-family.jpg" alt="A happy family together" class="h-full w-full object-cover" />
        </div>
        <div class="absolute bottom-0 left-0 h-[190px] w-[190px] overflow-hidden rounded-full shadow-[0_20px_44px_-18px_rgba(0,0,0,0.28)]">
          <img src="/images/community-group.jpg" alt="Friends from the community" class="h-full w-full object-cover" />
        </div>
        <div class="absolute bottom-[18px] right-0 flex items-center gap-3 rounded-[20px] bg-white px-5 py-4 shadow-[0_16px_36px_-16px_rgba(0,0,0,0.3)]">
          <div class="flex h-11 w-11 items-center justify-center rounded-full bg-blue-tint">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1F5AA6" stroke-width="1.8"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54z"/></svg>
          </div>
          <div>
            <div class="font-display text-xl font-extrabold text-forest-900">1,200+</div>
            <span class="text-xs font-medium text-muted">families supported</span>
          </div>
        </div>
      </div>
    </div>
    <WaveDivider fill="#fff" />
  </section>

  <!-- IMPACT -->
  {stats.length > 0 && (
    <section class="bg-white px-6 pb-16 pt-2 md:px-10">
      <div class="relative mx-auto -mt-14 max-w-[1240px]">
        <ImpactCounters client:visible stats={stats} />
      </div>
    </section>
  )}

  <!-- MISSION + VALUES -->
  <section class="bg-white px-6 pb-20 pt-6 md:px-10">
    <div class="mx-auto max-w-[1240px]">
      <div class="mb-14 grid items-center gap-10 md:grid-cols-[1fr_280px]">
        <div>
          <span class="mb-4 inline-flex items-center gap-2 font-display text-xs font-semibold uppercase tracking-[0.2em] text-emerald-deep">
            <span class="h-0.5 w-6 bg-emerald-deep"></span>Who we are
          </span>
          <h2 class="font-display text-3xl font-bold leading-[1.14] tracking-tight text-forest-900 md:text-[38px]">
            A home away from home for families finding their feet in Scotland.
          </h2>
          <p class="mt-4 max-w-[560px] text-lg leading-relaxed text-body">
            We walk alongside families from their first week in a new country to their brightest futures — guided by
            values that hold our community together.
          </p>
          <a href="/about" class="btn-lift mt-6 inline-flex items-center gap-2 rounded-full bg-emerald-deep px-6 py-3 font-display text-sm font-bold text-white">
            Our story
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class="h-56 w-full overflow-hidden rounded-[28px] shadow-[0_18px_44px_-26px_rgba(20,84,58,0.4)] md:h-[220px] md:w-auto">
          <img src="/images/family-support.jpg" alt="A family supported by Hope For Families" class="h-full w-full object-cover" />
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
        {values.map(([title, body]) => (
          <div class="rounded-[22px] bg-mint px-5 py-6 text-center">
            <div class="mx-auto mb-3.5 flex h-14 w-14 items-center justify-center rounded-full bg-white shadow-[0_8px_18px_-10px_rgba(20,84,58,0.4)]">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2E8B57" stroke-width="1.7"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54z"/></svg>
            </div>
            <div class="mb-1.5 font-display text-base font-bold text-forest-900">{title}</div>
            <p class="text-[13px] leading-relaxed text-muted">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROGRAMS -->
  {initiatives.length > 0 && (
    <section class="bg-mint px-6 py-20 md:px-10">
      <div class="mx-auto max-w-[1240px]">
        <div class="mb-10 text-center">
          <span class="mb-3.5 inline-flex items-center gap-2 font-display text-xs font-semibold uppercase tracking-[0.2em] text-gold-deep">
            <span class="h-0.5 w-6 bg-gold"></span>What we do<span class="h-0.5 w-6 bg-gold"></span>
          </span>
          <h2 class="font-display text-3xl font-bold tracking-tight text-forest-900 md:text-[38px]">Our programs, one community.</h2>
        </div>

        <a href={`/programs/${flagship.slug}`} class="card-lift mb-5 grid overflow-hidden rounded-[28px] bg-white shadow-[0_22px_48px_-28px_rgba(20,84,58,0.4)] md:grid-cols-[1.1fr_1fr]">
          <div class="relative min-h-[220px] md:min-h-[320px]">
            <img src="/images/food-bank.jpg" alt={flagship.title} class="absolute inset-0 h-full w-full object-cover" />
            <span class="absolute left-4 top-4 rounded-full bg-gold px-3.5 py-2 font-display text-[11px] font-bold uppercase tracking-[0.08em] text-forest-900">Flagship</span>
          </div>
          <div class="p-8 md:p-11">
            <h3 class="mb-3 font-display text-2xl font-bold leading-[1.14] text-forest-900 md:text-[27px]">{flagship.title}</h3>
            {flagship.tagline && <p class="mb-3 font-display text-sm font-semibold text-emerald-deep">{flagship.tagline}</p>}
            <p class="mb-6 leading-relaxed text-body">{flagship.description}</p>
            <span class="inline-flex items-center gap-2 rounded-full bg-emerald-deep px-5.5 py-3 font-display text-sm font-bold text-white">
              Learn more
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </div>
        </a>

        {restInitiatives.length > 0 && (
          <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
            {restInitiatives.map((initiative) => {
              const photo = programPhotos[initiative.slug];
              return (
                <a href={`/programs/${initiative.slug}`} class="card-lift overflow-hidden rounded-[22px] bg-white shadow-[0_14px_34px_-26px_rgba(20,84,58,0.4)]">
                  {photo ? (
                    <div class="h-32 w-full overflow-hidden">
                      <img src={photo} alt={initiative.title} class="h-full w-full object-cover" />
                    </div>
                  ) : null}
                  <div class="p-6">
                    {!photo && (
                      <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-[linear-gradient(150deg,#1F5AA6,#3FAE68)]">
                        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.6"><path d="M12 3l9 4.5-9 4.5-9-4.5L12 3z"/><path d="M3 12l9 4.5 9-4.5"/></svg>
                      </div>
                    )}
                    <h3 class="mb-1.5 font-display text-[17px] font-bold leading-tight text-forest-900">{initiative.title}</h3>
                    <p class="text-[13px] leading-relaxed text-muted">{initiative.tagline || initiative.description}</p>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- MOMENTS GALLERY -->
  <section class="bg-white px-6 py-20 md:px-10">
    <div class="mx-auto max-w-[1240px]">
      <div class="mb-10 text-center">
        <span class="mb-3.5 inline-flex items-center gap-2 font-display text-xs font-semibold uppercase tracking-[0.2em] text-emerald-deep">
          <span class="h-0.5 w-6 bg-emerald-deep"></span>Real Moments<span class="h-0.5 w-6 bg-emerald-deep"></span>
        </span>
        <h2 class="font-display text-3xl font-bold tracking-tight text-forest-900 md:text-[38px]">Straight from our events.</h2>
        <p class="mx-auto mt-3 max-w-[560px] text-body">A glimpse of the families, volunteers, and celebrations that make Hope For Families what it is.</p>
      </div>
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
        {[
          ['moment-1.jpg', 'Easter celebration at Hope For Families'],
          ['moment-2.jpg', 'Family fun at our Easter event'],
          ['moment-3.jpg', 'Community gathered at our summer festival'],
          ['moment-4.jpg', 'Tug of war at the summer festival'],
          ['moment-5.jpg', 'A warm welcome at Easter'],
          ['moment-6.jpg', 'Sack races at our summer festival'],
          ['moment-7.jpg', 'Volunteers at our Cake Event'],
          ['moment-8.jpg', 'Young people enjoying our Cake Event'],
        ].map(([src, alt]) => (
          <div class="card-lift h-32 overflow-hidden rounded-2xl shadow-[0_10px_26px_-18px_rgba(20,84,58,0.4)] md:h-44">
            <img src={`/images/${src}`} alt={alt} class="h-full w-full object-cover" />
          </div>
        ))}
      </div>
      <div class="mt-9 text-center">
        <a href="/success-stories" class="navlink inline-flex items-center gap-1.5 font-display text-sm font-bold text-emerald-deep">
          See more stories
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2E8B57" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- STORY -->
  {featured && (
    <section class="bg-white px-6 py-20 md:px-10">
      <div class="relative mx-auto max-w-[1240px] overflow-hidden rounded-[28px] bg-[linear-gradient(150deg,#1F7A4D,#14543A)] p-8 md:p-14">
        <div class="pointer-events-none absolute -right-16 -top-16 h-[280px] w-[280px] rounded-full bg-[radial-gradient(circle,rgba(244,185,66,0.34),transparent_68%)]"></div>
        <div class="relative grid items-center gap-10 md:grid-cols-[240px_1fr]">
          <div class="relative mx-auto h-56 w-56 overflow-hidden rounded-[130px_130px_120px_120px] md:mx-0 md:h-[260px] md:w-auto">
            <img src="/images/volunteer-portrait.jpg" alt={featured.name} class="h-full w-full object-cover" />
          </div>
          <div>
            <svg width="46" height="46" viewBox="0 0 24 24" fill="#F4B942" class="mb-4"><path d="M9.5 6C6.5 7.5 5 10 5 13v5h6v-6H8c0-2 .8-3.6 2.5-4.5L9.5 6zm9 0C15.5 7.5 14 10 14 13v5h6v-6h-3c0-2 .8-3.6 2.5-4.5L18.5 6z"/></svg>
            <p class="mb-6 font-display text-2xl font-medium leading-[1.42] tracking-tight text-white md:text-[29px]">
              &ldquo;{featured.content}&rdquo;
            </p>
            <div class="flex flex-wrap items-center justify-between gap-4">
              <div class="flex items-center gap-3">
                <span class="font-display text-base font-bold text-gold">{featured.name}</span>
                {featured.category && (
                  <>
                    <span class="h-[5px] w-[5px] rounded-full bg-white/50"></span>
                    <span class="text-[15px] text-white/82">{featured.category}</span>
                  </>
                )}
              </div>
              <a href="/success-stories" class="btn-lift inline-flex items-center gap-2 rounded-full bg-white px-5 py-2.5 font-display text-sm font-bold text-forest-900">
                Read more stories
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#14543A" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- EVENTS -->
  {upcomingEvents.length > 0 && (
    <section class="bg-mint px-6 py-20 md:px-10">
      <div class="mx-auto max-w-[1240px]">
        <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
          <div>
            <span class="mb-3.5 inline-flex items-center gap-2 font-display text-xs font-semibold uppercase tracking-[0.2em] text-emerald-deep">
              <span class="h-0.5 w-6 bg-emerald-deep"></span>What's on
            </span>
            <h2 class="font-display text-3xl font-bold tracking-tight text-forest-900 md:text-[38px]">Come along this week.</h2>
          </div>
          <a href="/events" class="navlink inline-flex items-center gap-1.5 font-display text-sm font-bold text-emerald-deep">
            Full calendar
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2E8B57" stroke-width="2.4"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <div class="grid gap-6 md:grid-cols-[300px_1fr]">
          <div class="h-40 w-full overflow-hidden rounded-[24px] shadow-[0_18px_44px_-26px_rgba(20,84,58,0.4)] md:h-full md:min-h-[260px]">
            <img src="/images/moment-3.jpg" alt="Community gathered at one of our events" class="h-full w-full object-cover" />
          </div>
          <div class="flex flex-col gap-3.5">
            {upcomingEvents.map((event, i) => (
              <a href={`/events/${event.slug}`} class="card-lift flex flex-col gap-4 rounded-[18px] bg-white p-5 shadow-[0_12px_30px_-26px_rgba(20,84,58,0.4)] sm:flex-row sm:items-center md:gap-6">
                <div class="flex min-w-0 flex-1 items-center gap-4">
                  <div class="flex h-[60px] w-[60px] shrink-0 flex-col items-center justify-center rounded-full bg-mint-tint">
                    <span class="font-display text-[11px] font-bold tracking-[0.06em] text-emerald-deep">{formatDate(event.start_at).split(' ')[0].toUpperCase()}</span>
                    <span class="mt-0.5 font-display text-xl font-extrabold text-forest-900">{new Date(event.start_at).getDate()}</span>
                  </div>
                  <div class="min-w-0 flex-1">
                    <h3 class="mb-0.5 font-display text-lg font-bold leading-tight text-forest-900">{event.title}</h3>
                    <p class="text-sm text-muted">{formatDate(event.start_at)}{event.location ? ` · ${event.location}` : ''}</p>
                  </div>
                </div>
                <span class={`self-start rounded-full px-5 py-2.5 font-display text-sm font-bold text-white sm:shrink-0 ${spineColors[i % spineColors.length]}`}>Details</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <CtaBand
    title="Be part of someone's brighter future."
    description="Whether you give, volunteer or partner with us — every act of hope helps a family belong."
    bgImage="/images/moment-2.jpg"
  />
</Layout>
