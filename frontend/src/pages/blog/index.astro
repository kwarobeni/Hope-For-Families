---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import { api } from '../../lib/api';

const posts = await api.posts();
---

<Layout title="Blog & News" description="News, updates, and stories from Hope For Families — a community-led charity in Dundee, Scotland.">
  <PageHero eyebrow="News" title="Blog & news." maxWidth="max-w-[520px]" />

  <section class="bg-white px-6 pb-21 pt-10 md:px-10">
    <div class="mx-auto max-w-[800px]">
      {posts.length === 0 && <p class="text-center text-muted">No posts published yet — check back soon.</p>}

      <div class="flex flex-col gap-5">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="card-lift rounded-[22px] border border-border-soft bg-white p-7 shadow-[0_14px_34px_-28px_rgba(20,84,58,0.4)]">
            <h2 class="font-display text-2xl font-bold text-forest-900">{post.title}</h2>
            <p class="mt-1 text-sm font-medium text-muted">
              {new Date(post.published_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
            </p>
            <p class="mt-3 leading-relaxed text-body">{post.excerpt}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
